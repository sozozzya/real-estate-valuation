{
  "name": "real-estate-valuation",
  "version": "1.0.0",
  "private": true,
  "description": "Real estate valuation app (FastAPI backend + Vite/React frontend)",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0",
    "python": ">=3.10"
  },
  "scripts": {
    "setup": "npm run setup:backend && npm run setup:frontend",
    "setup:backend": "python -m pip install --upgrade pip && python -m pip install -r backend/requirements.txt",
    "setup:frontend": "npm --prefix frontend install",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "python -m uvicorn src.presentation.main:app --reload --app-dir backend",
    "dev:frontend": "npm --prefix frontend run dev",
    "build": "npm run build:frontend",
    "build:frontend": "npm --prefix frontend run build",
    "lint": "npm run lint:backend && npm run lint:frontend",
    "lint:backend": "python -m ruff check backend/src",
    "lint:frontend": "npm --prefix frontend run lint",
    "format": "npm run format:backend && npm run format:frontend",
    "format:backend": "python -m black backend/src",
    "format:frontend": "npm --prefix frontend run format",
    "typecheck": "npm --prefix frontend run typecheck",
    "clean": "node -e \"const fs=require('fs'); ['backend/.venv','frontend/node_modules','frontend/dist'].forEach(p=>fs.rmSync(p,{recursive:true,force:true}));\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
